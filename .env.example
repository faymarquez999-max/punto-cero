# Copia este archivo a .env y rellena los valores
# En GitHub Actions estos van como "Secrets" del repo (Settings -> Secrets and variables -> Actions)

# Telegram bot — créalo con @BotFather en Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Groq API (IA gratis) — saca tu key en https://console.groq.com/keys
GROQ_API_KEY=

# Opcional: Reddit oficial (mejor que JSON público). Si vacío, usa endpoint público.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=narrative-alpha-hunter/1.0

# Opcional: Telegram channels (Telethon)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=

# Opcional: Birdeye
BIRDEYE_API_KEY=

# Opcional: Solana Tracker API key (free tier — solanatracker.io)
SOLANATRACKER_API_KEY=

# Opcional: Helius RPC URL para smart money tracking real-time
# Sin esto usa public RPC (más lento y rate-limited)
# Free key en helius.dev → copia la URL completa con tu key
HELIUS_RPC_URL=
